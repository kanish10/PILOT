# ── Groq API ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=<your_groq_api_key_here>

# ── Groq model selection (defaults match claude.md spec) ──────────────────────
PLANNER_MODEL=llama-3.3-70b-versatile
ACTOR_MODEL=llama-3.3-70b-versatile
VERIFIER_MODEL=llama-3.1-8b-instant
VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Ollama backup (ngrok URL from the other laptop) ───────────────────────────
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=<your_ollama_base_url_here>
OLLAMA_MODEL=qwen3:8b

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Task behaviour ────────────────────────────────────────────────────────────
MAX_RETRIES=3
MAX_BACK_PRESSES=5
MAX_ACTIONS_PER_STEP=20
